# OpenClaw Gateway Configuration
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=18789
OPENCLAW_TOKEN=your_gateway_token_here

# Speech-to-Text Configuration
# Options: whisper, faster-whisper, openai
STT_BACKEND=whisper
WHISPER_MODEL=base
WAKE_WORD=hey reachy

# OpenAI API Key (required for --stt openai)
OPENCLAW_OPENAI_TOKEN=your_openai_api_key_here
# Alternative: OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs TTS Configuration
REACHY_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Alternative: ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional ElevenLabs settings (defaults shown)
REACHY_ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
REACHY_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
REACHY_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
